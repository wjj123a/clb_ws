  </link>

  <joint name="J4" type="continuous">
    <origin xyz="-0.19879978611665 0.119285316479219 0.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Empty_Link4" />
    <axis xyz="0 1 0" />
    <limit effort="200" velocity="20" />
    <dynamics damping="0.5" friction="0.1" />
  </joint>

  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.01" />
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5" />
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0.02 0 0.22" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
  </joint>

  <link name="laser_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="2e-5" ixy="0" ixz="0" iyy="2e-5" iyz="0" izz="2e-5" />
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0.34 0 0.36" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser_link" />
  </joint>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.05" />
      <inertia ixx="2e-5" ixy="0" ixz="0" iyy="2e-5" iyz="0" izz="2e-5" />
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.30 0 0.28" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_link" />
  </joint>

  <link name="camera_optical_link" />

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679" />
    <parent link="camera_link" />
    <child link="camera_optical_link" />
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/White</material>
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
    <slip1>0.01</slip1>
    <slip2>0.01</slip2>
    <kp>1000000.0</kp>
    <kd>200.0</kd>
    <maxVel>2.0</maxVel>
    <minDepth>0.001</minDepth>
  </gazebo>

  <gazebo reference="front_drive_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>2.4</mu1>
    <mu2>1.2</mu2>
    <fdir1>1 0 0</fdir1>
    <slip1>0.0</slip1>
    <slip2>0.01</slip2>
    <kp>5000000.0</kp>
    <kd>200.0</kd>
    <maxVel>2.0</maxVel>
    <minDepth>0.001</minDepth>
  </gazebo>

  <gazebo reference="Empty_Link1">
    <material>Gazebo/Black</material>
    <mu1>1.6</mu1>
    <mu2>0.8</mu2>
    <fdir1>1 0 0</fdir1>
    <slip1>0.0</slip1>
    <slip2>0.02</slip2>
