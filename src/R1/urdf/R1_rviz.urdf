<?xml version="1.0" encoding="utf-8"?>
<robot name="R1_rviz">
  <material name="frame_white">
    <color rgba="0.92 0.92 0.92 1.0" />
  </material>
  <material name="wheel_black">
    <color rgba="0.15 0.15 0.15 1.0" />
  </material>
  <material name="sensor_gray">
    <color rgba="0.55 0.55 0.55 1.0" />
  </material>

  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0.04075" rpy="0 0 0" />
    <parent link="base_footprint" />
    <child link="base_link" />
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0.02 0 0.17" rpy="0 0 0" />
      <geometry>
        <box size="0.56 0.29 0.24" />
      </geometry>
      <material name="frame_white" />
    </visual>
    <visual>
      <origin xyz="0.02 0 0.34" rpy="0 0 0" />
      <geometry>
        <box size="0.48 0.25 0.10" />
      </geometry>
      <material name="frame_white" />
    </visual>
  </link>

  <link name="Empty_Link1">
    <visual>
      <origin xyz="0 0.0175 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.04075" length="0.040" />
      </geometry>
      <material name="wheel_black" />
    </visual>
  </link>

  <joint name="J1" type="continuous">
    <origin xyz="0.220127909860013 0.142085316479216 0.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Empty_Link1" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="Empty_Link2">
    <visual>
      <origin xyz="0 0.0020 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.04075" length="0.040" />
      </geometry>
      <material name="wheel_black" />
    </visual>
  </link>

  <joint name="J2" type="continuous">
    <origin xyz="0.220127909860013 -0.122535316479216 0.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Empty_Link2" />
    <axis xyz="0 -1 0" />
  </joint>

  <link name="Empty_Link3">
    <visual>
      <origin xyz="0 -0.0010 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.04075" length="0.0465" />
      </geometry>
      <material name="wheel_black" />
    </visual>
  </link>

  <joint name="J3" type="continuous">
    <origin xyz="-0.19879978611665 -0.122535316479219 0.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Empty_Link3" />
    <axis xyz="0 -1 0" />
  </joint>

  <link name="Empty_Link4">
    <visual>
      <origin xyz="0 -0.0020 0" rpy="1.57079632679 0 0" />
      <geometry>
        <cylinder radius="0.04075" length="0.0465" />
      </geometry>
      <material name="wheel_black" />
    </visual>
  </link>

  <joint name="J4" type="continuous">
    <origin xyz="-0.19879978611665 0.119285316479219 0.0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="Empty_Link4" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.03 0.03 0.015" />
      </geometry>
      <material name="sensor_gray" />
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0.02 0 0.22" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="imu_link" />
  </joint>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.025" length="0.05" />
      </geometry>
      <material name="sensor_gray" />
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0.34 0 0.36" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="laser_link" />
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.04 0.03 0.03" />
      </geometry>
      <material name="sensor_gray" />
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.30 0 0.28" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="camera_link" />
  </joint>

  <link name="camera_optical_link" />

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679" />
    <parent link="camera_link" />
    <child link="camera_optical_link" />
  </joint>
</robot>
