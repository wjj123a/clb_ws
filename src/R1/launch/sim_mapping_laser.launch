<launch>
  <arg
    name="world_name"
    default="$(find r1)/worlds/charging_arena.world" />
  <arg
    name="gui"
    default="true" />
  <arg
    name="rviz"
    default="true" />
  <arg
    name="enable_planar_test_guard"
    default="false" />
  <arg
    name="x"
    default="0.0" />
  <arg
    name="y"
    default="0.0" />
  <arg
    name="z"
    default="0.001" />
  <arg
    name="yaw"
    default="0.0" />
  <arg
    name="cmd_vel_max_linear_x"
    default="0.10" />
  <arg
    name="cmd_vel_max_angular_z"
    default="0.25" />
  <arg
    name="cmd_vel_max_linear_accel"
    default="0.18" />
  <arg
    name="cmd_vel_max_angular_accel"
    default="0.40" />

  <include
    file="$(find r1)/launch/sim_bringup.launch">
    <arg
      name="world_name"
      value="$(arg world_name)" />
    <arg
      name="gui"
      value="$(arg gui)" />
    <arg
      name="rviz"
      value="$(arg rviz)" />
    <arg
      name="rviz_config"
      value="$(find r1)/rviz/mapping_laser.rviz" />
    <arg
      name="enable_planar_test_guard"
      value="$(arg enable_planar_test_guard)" />
    <arg
      name="enable_navigation"
      value="false" />
    <arg
      name="enable_docking"
      value="false" />
    <arg
      name="x"
      value="$(arg x)" />
    <arg
      name="y"
      value="$(arg y)" />
    <arg
      name="z"
      value="$(arg z)" />
    <arg
      name="yaw"
      value="$(arg yaw)" />
    <arg
      name="cmd_vel_max_linear_x"
      value="$(arg cmd_vel_max_linear_x)" />
    <arg
      name="cmd_vel_max_angular_z"
      value="$(arg cmd_vel_max_angular_z)" />
    <arg
      name="cmd_vel_max_linear_accel"
      value="$(arg cmd_vel_max_linear_accel)" />
    <arg
      name="cmd_vel_max_angular_accel"
      value="$(arg cmd_vel_max_angular_accel)" />
  </include>

  <include
    file="$(find r1)/launch/mapping_laser.launch" />
</launch>
