<launch>
  <arg
    name="base_local_planner_config"
    default="$(find r1)/config/base_local_planner.yaml" />
  <arg
    name="costmap_common_config"
    default="$(find r1)/config/costmap_common.yaml" />
  <arg
    name="global_costmap_config"
    default="$(find r1)/config/global_costmap.yaml" />
  <arg
    name="local_costmap_config"
    default="$(find r1)/config/local_costmap.yaml" />
  <arg
    name="map_file"
    default="$(find r1)/maps/charging_arena.yaml" />
  <arg
    name="map_mode"
    default="static" />
  <arg
    name="use_amcl"
    default="true" />
  <arg
    name="use_ground_truth_localization"
    default="false" />
  <arg
    name="use_odom_sanitizer"
    default="false" />
  <arg
    name="odom_input_topic"
    default="ground_truth_odom" />
  <arg
    name="odom_topic"
    default="odom" />
  <arg
    name="initial_pose_x"
    default="0.0" />
  <arg
    name="initial_pose_y"
    default="0.0" />
  <arg
    name="initial_pose_a"
    default="0.0" />
  <arg
    name="use_goal_sanitizer"
    default="true" />

  <node
    if="$(eval arg('map_mode') == 'static')"
    name="map_server"
    pkg="map_server"
    type="map_server"
    args="$(arg map_file)"
    output="screen" />

  <node
    if="$(eval arg('map_mode') == 'static' and not arg('use_amcl') and not arg('use_ground_truth_localization'))"
    name="map_to_odom"
    pkg="tf2_ros"
    type="static_transform_publisher"
    args="0 0 0 0 0 0 map odom" />

  <node
    if="$(eval arg('map_mode') == 'static' and arg('use_ground_truth_localization'))"
    name="ground_truth_localization"
    pkg="r1"
    type="ground_truth_localization.py"
    output="screen">
    <param
      name="ground_truth_topic"
      value="$(arg odom_input_topic)" />
    <param
      name="map_frame_id"
      value="map" />
    <param
      name="odom_frame_id"
      value="odom" />
    <param
      name="base_frame_id"
      value="base_footprint" />
  </node>

  <node
    if="$(arg use_odom_sanitizer)"
    name="odom_sanitizer"
    pkg="r1"
    type="odom_sanitizer.py"
    output="screen">
    <param
      name="input_topic"
      value="$(arg odom_input_topic)" />
    <param
      name="output_topic"
      value="$(arg odom_topic)" />
    <param
      name="publish_tf"
      value="false" />
    <param
      name="output_frame_id"
      value="odom" />
  </node>

  <node
    if="$(eval arg('map_mode') == 'static' and arg('use_amcl') and not arg('use_ground_truth_localization'))"
    name="amcl"
    pkg="amcl"
    type="amcl"
    clear_params="true"
    output="screen">
    <rosparam
      command="load"
      file="$(find r1)/config/amcl.yaml" />
    <param
      name="initial_pose_x"
      value="$(arg initial_pose_x)" />
    <param
      name="initial_pose_y"
      value="$(arg initial_pose_y)" />
    <param
      name="initial_pose_a"
      value="$(arg initial_pose_a)" />
  </node>

  <node
    if="$(arg use_goal_sanitizer)"
    name="goal_sanitizer"
    pkg="r1"
    type="goal_sanitizer.py"
    output="screen">
    <param
      name="map_topic"
      value="/map" />
    <param
      name="input_topic"
      value="/move_base_simple/goal" />
    <param
      name="output_topic"
      value="/move_base_simple/goal_sanitized" />
    <param
      name="clearance_radius"
      value="0.70" />
    <param
      name="search_radius"
      value="2.20" />
    <param
      name="occupancy_threshold"
      value="50" />
    <param
      name="base_frame_id"
      value="base_footprint" />
    <param
      name="arrival_radius"
      value="0.30" />
    <param
      name="sanitize_min_shift"
      value="0.10" />
    <param
      name="approach_clearance_radius"
      value="0.35" />
    <param
      name="robot_distance_weight"
      value="0.10" />
    <param
      name="blocked_approach_penalty"
      value="8.0" />
    <param
      name="open_space_weight"
      value="1.40" />
    <param
      name="open_space_radius"
      value="1.20" />
  </node>

  <node
    name="move_base"
    pkg="move_base"
    type="move_base"
    clear_params="true"
    output="screen">
    <remap
      if="$(arg use_goal_sanitizer)"
      from="move_base_simple/goal"
      to="move_base_simple/goal_sanitized" />
    <rosparam
      command="load"
      file="$(arg base_local_planner_config)" />
    <rosparam
      command="load"
      file="$(find r1)/config/move_base_recovery.yaml" />
    <rosparam
      command="load"
      file="$(find r1)/config/global_planner.yaml" />
    <rosparam
      command="load"
      file="$(arg costmap_common_config)"
      ns="global_costmap" />
    <rosparam
      command="load"
      file="$(arg global_costmap_config)"
      ns="global_costmap" />
    <rosparam
      command="load"
      file="$(arg costmap_common_config)"
      ns="local_costmap" />
    <rosparam
      command="load"
      file="$(arg local_costmap_config)"
      ns="local_costmap" />
    <param
      name="DWAPlannerROS/odom_topic"
      value="$(arg odom_topic)" />
    <param
      name="TrajectoryPlannerROS/odom_topic"
      value="$(arg odom_topic)" />
  </node>
</launch>
