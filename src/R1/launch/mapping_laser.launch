<launch>
  <arg
    name="scan_topic"
    default="scan" />
  <arg
    name="base_frame"
    default="base_footprint" />
  <arg
    name="odom_frame"
    default="odom" />
  <arg
    name="map_frame"
    default="map" />

  <node
    name="slam_gmapping"
    pkg="gmapping"
    type="slam_gmapping"
    clear_params="true"
    output="screen">
    <rosparam
      command="load"
      file="$(find r1)/config/gmapping_mapping.yaml" />
    <remap
      from="scan"
      to="$(arg scan_topic)" />
    <param
      name="base_frame"
      value="$(arg base_frame)" />
    <param
      name="odom_frame"
      value="$(arg odom_frame)" />
    <param
      name="map_frame"
      value="$(arg map_frame)" />
  </node>
</launch>
